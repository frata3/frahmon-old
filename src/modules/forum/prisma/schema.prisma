generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRESQL_FORUM_URL")
}

model User {
  id       String @id @default(uuid())
  username String @unique
  fullname String
  avatar   String @default("/assets/pictures/default-avatar.png")

  posts Post[] @relation("UserPosts")
  likes Like[] @relation("UserLikes")
}

model Post {
  id        String   @id
  slug      String?
  title     String?
  type      String   @default("forum")
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User   @relation("UserPosts", fields: [authorId], references: [id])

  parentId String?
  parent   Post?   @relation("PostReplies", fields: [parentId], references: [id])
  replies  Post[]  @relation("PostReplies")

  quoteId String?
  quote   Post?   @relation("PostQuotes", fields: [quoteId], references: [id])
  quotes  Post[]  @relation("PostQuotes")

  repostId String?
  repost   Post?   @relation("PostReposts", fields: [repostId], references: [id])
  reposts  Post[]  @relation("PostReposts")

  likes Like[]

  likeCount   Int @default(0)
  viewCount   Int @default(0)
  replyCount  Int @default(0)
  quoteCount  Int @default(0)
  repostCount Int @default(0)

  @@index([slug])
}

model Like {
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("UserLikes", fields: [userId], references: [id])

  @@unique([postId, userId])
}
