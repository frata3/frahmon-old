<section>
  <h1>دسته‌بندی‌های محبوب</h1>
  <ul>
    <% categories.forEach(category => { %>
      <li  style="display: inline-block; margin: 0 20px;">
        <h2>
          <a href="/category/<%= category.slug %>">
            <%= category.name %> 
          </a>
        </h2>
        <ul>
          <% category.topics.forEach(topic => { %>
            <li>
              <a href="/topic/<%= topic.slug %>">
                <%= topic.name %> 
              </a>
            </li>
          <% }) %>
        </ul>
      </li>
    <% }) %>
  </ul>
</section>
 