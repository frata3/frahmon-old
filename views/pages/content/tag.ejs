<main>
  <h1>برچسب: <%= tag.name %></h1>

  <section>
      <h2>پست‌های بلاگ</h2>
      <% if (posts.length) { %>
          <ul>
              <% posts.forEach(post => { %>
                  <li><a href="/blog/post/<%= post.slug %>"><%= post.title %></a></li>
              <% }); %>
          </ul>
      <% } else { %>
          <p>هیچ پست بلاگی با این برچسب موجود نیست.</p>
      <% } %>
  </section>

  <section>
      <h2>محصولات فروشگاه</h2>
      
      <% if (typeof storeProducts !== 'undefined' && storeProducts.length) { %>
          <ul>
              <% storeProducts.forEach(product => { %>
                  <li><a href="/store/<%= product.slug %>"><%= product.name %></a></li>
              <% }); %>
          </ul>
      <% } else { %>
          <p>محصولی با این برچسب پیدا نشد.</p>
      <% } %>
  </section>

  <section>
      <h2>پست‌های فروم</h2>
      
      <% if (typeof forumPosts !== 'undefined' && forumPosts.length) { %>
          <ul>
              <% forumPosts.forEach(post => { %>
                  <li><a href="/forum/<%= post.slug %>"><%= post.title %></a></li>
              <% }); %>
          </ul>
      <% } else { %>
          <p>هیچ پستی در فروم با این برچسب وجود ندارد.</p>
      <% } %>
  </section>
</main>
