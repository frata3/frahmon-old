<section>
  <div class="auth-box auth-container">
    <h2 id="form-title">Welcome</h2>
    <p class="subtitle" id="form-subtitle">Enter your email to continue</p>

    <form id="auth-form" novalidate>

      <!-- Step 1: Email -->
      <div class="form-group active" id="email-group">
        <label for="email">ایمیل</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required />
        <span class="warning error-message" id="email-error"></span>
      </div>

      <!-- Step 2: Password (Login) -->
      <div class="form-group" id="password-group">
        <label for="password">رمز عبور</label>
        <input type="password" id="password" name="password" placeholder="Enter your password" required />
        <span class="warning error-message" id="password-error"></span>
      </div>

      <!-- Step 3: Full Registration -->
      <div class="form-group" id="username-group">
        <label for="username"> نام کاربری  </label>
        <input type="text" id="username" name="username" placeholder="random4321" required />
        <span class="warning error-message" id="username-error"></span>
      </div>

      <!-- Step 4: Full Registration -->
      <div class="form-group" id="fullname-group">
        <label for="fullname">نام و نام خانوادگی</label>
        <input type="text" id="fullname" name="fullname" placeholder="John Doe" required />
        <span class="warning error-message" id="fullname-error"></span>
      </div>

      <div class="form-group" id="new-password-group">
        <label for="new-password">رمز عبور</label>
        <input type="password" id="new-password" name="new-password" placeholder="Create a password" required />
        <span class="warning error-message" id="new-password-error"></span>
      </div>

      <div class="form-group" id="confirm-password-group">
        <label for="confirm-password">تکرار رمز عبور</label>
        <input type="password" id="confirm-password" name="confirm-password" placeholder="Confirm your password" required />
        <span class="warning error-message" id="confirm-password-error"></span>
      </div>

      <button type="submit" id="submit-btn">Continue</button>
      <button type="button" class="back-button" id="back-btn" style="display: none;">Back</button>

      <div class="loading" id="loading">Processing...</div>
    </form>
  </div>
</section>