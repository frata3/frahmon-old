<div class="container">
  <h2>اطلاعات کاربری</h2>
  <div class="profile-grid">
    <div class="profile-item">نام کامل</div>
    <div class="profile-item" id="fullname"><%= user.fullname %></div>
    <button class="edit-btn" data-field="fullname" data-label="نام کامل" data-description="نام خود را در این بخش تغییر دهید.">✏️</button>

    <div class="profile-item">ایمیل</div>
    <div class="profile-item" id="email"><%= user.email %></div>
    <button class="edit-btn" data-field="email" data-label="ایمیل" data-description="ایمیل خود را تغییر دهید. این ایمیل برای ورود استفاده می‌شود.">✏️</button>

    <div class="profile-item">شماره موبایل</div>
    <div class="profile-item" id="phone">09XXXXXXXXX</div>
    <button class="edit-btn" data-field="phone" data-label="شماره موبایل" data-description="شماره موبایل خود را تغییر دهید.">✏️</button>

    <div class="profile-item">آدرس</div>
    <div class="profile-item" id="address">تهران، خیابان مثال، پلاک 12</div>
    <button class="edit-btn" data-field="address" data-label="آدرس" data-description="آدرس محل سکونت خود را تغییر دهید.">✏️</button>

    <div class="profile-item">رمز عبور</div>
    <div class="profile-item" id="password">********</div>
<!-- 
    <div class="profile-item">
      <span id="password-display">********</span>
      <button id="toggle-password" class="eye-btn">👁️</button>
    </div> -->
    <button class="edit-btn" data-field="password" data-label="رمز عبور" data-description="رمز عبور خود را تغییر دهید.">✏️</button>
  </div>
</div>

<div id="edit-modal" class="modal">
    <div class="modal-content">
      <span class="close-btn">&times;</span>
      <h3 id="modal-title">ویرایش اطلاعات</h3>
      <p id="modal-description"></p>
      <form id="edit-form">
        <input type="hidden" id="field-name" name="field">
        <div id="field-value"></div>
        <button type="submit">ذخیره</button>
      </form>
      <div id="modal-message" class="modal-message"></div>
    </div>
  </div>
  