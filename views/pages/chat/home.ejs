<script>
  window.currentUserId = "<%= currentUserId %>";
  let temp = "<%= toUsername %>";
  if (temp.length > 1) {
    window.toUsername = "<%= toUsername %>";
  }
</script>
<div class="chat-container">
  <div class="chat-sidebar">
    <h2 class="chat-title">گفت‌وگوها</h2>
    <% if (chats.length===0) { %>
    <p class="no-chat">گفت‌وگویی یافت نشد.</p>
    <% } %>
    <% chats.forEach((chat)=> { %> 
    <% const otherUser = chat.members.find((m)=> m._id.toString() !== currentUserId.toString()); %>
    <div class="chat-user" data-username="<%= otherUser.username %>">
      <div>
        <p>
          <%= otherUser.fullname || otherUser.username %>
        </p>
        <small>
          <% if (chat.lastMessage) { %>
          <%= chat.lastMessage.content.slice(0, 30) %>
          <br />
          <%= new Date(chat.lastMessage.createdAt).toLocaleTimeString("fa-IR", { hour: '2-digit' ,
                        minute: '2-digit' }) %>
          <% } else { %> پیامی نیست <% } %>
        </small>
      </div>
    </div>
    <% }) %>
  </div>

  <div class="chat-panel" id="chat-panel"></div>
  <div class="chat-sidebar"></div>
</div>