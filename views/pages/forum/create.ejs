<section class="create-post-container">
  <form action="/forum/create" method="POST" class="create-post-form">
    <input type="text" name="title" placeholder="عنوان (اختیاری)" />
    <textarea name="content" placeholder="متن پست..." required></textarea>

    <input type="hidden" name="parentId" value="<%= parentId || '' %>">
    <input type="hidden" name="quoteId" value="<%= quoteId || '' %>">
    <input type="hidden" name="repostId" value="<%= repostId || '' %>">

    <button type="submit">ارسال</button>
  </form>
</section>