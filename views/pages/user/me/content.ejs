
<section class="content-manager">
  <h1>مدیریت محتوا</h1>

  <div class="tree-view">
    <% categories.forEach(category => { %>
      <div class="category">
        <div class="category-name" onclick="toggleTopics('<%= category._id %>')">
          ▶️ <%= category.name %>
        </div>
        <div class="topics hidden" id="topics-<%= category._id %>">
          <% category.topics.forEach(topic => { %>
            <div class="topic">
              <div class="topic-name" onclick="toggleTags('<%= category._id %>-<%= topic._id %>')">
                &nbsp;&nbsp;📁 <%= topic.name %>
              </div>
              <div class="tags hidden" id="tags-<%= category._id %>-<%= topic._id %>">
                <% topic.tags.forEach(tag => { %>
                  <div class="tag">
                    &nbsp;&nbsp;&nbsp;&nbsp;🏷️ <%= tag.name %>
                  </div>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<style>
  section{
    margin: 10px;
  }
  .tree-view {
    font-family: sans-serif;
    margin: 1rem;
    line-height: 1.6;
  }
  .category-name, .topic-name {
    cursor: pointer;
    padding: 4px;
    margin: 2px 0;
    background: #f4f4f4;
    border-radius: 4px;
  }
  .tags, .topics {
    margin-right: 1rem;
  }
  .tag {
    margin-right: 2rem;
    padding: 2px 0;
  }
  .hidden {
    display: none;
  }
</style>

<script>
  function toggleTopics(id) {
    const el = document.getElementById("topics-" + id);
    el.classList.toggle("hidden");
  }

  function toggleTags(id) {
    const el = document.getElementById("tags-" + id);
    el.classList.toggle("hidden");
  }
</script>
