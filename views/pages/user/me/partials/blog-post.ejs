<div class="post-card post-blog">
    <a href="/blog/<%= post._id %>" target="_blank">
      <h2 class="post-title"><%= post.title %></h2>
    </a>
    <p class="post-desc"><%= post.description %></p>
    <div class="post-meta">
      <span>📝 وبلاگ</span>
      <span><%= new Date(post.createdAt).toLocaleDateString('fa-IR') %></span>
    </div>
  </div>
  