<div class="container">
  <h2>اطلاعات کاربری</h2>
  <div class="profile-grid">
    <form class="profile-form" data-field="email">
      <label>ایمیل</label>
      <input type="text" name="value" value="<%= user.email %>">
      <button type="submit">ذخیره</button>
      <div class="msg"></div>
    </form>

    <form class="profile-form" data-field="username">
      <label>نام کاربری</label>
      <input type="text" name="value" value="<%= user.username %>">
      <button type="submit">ذخیره</button>
      <div class="msg"></div>
    </form>

    <form class="profile-form" data-field="fullname">
      <label>نام کامل</label>
      <input type="text" name="value" value="<%= user.fullname %>">
      <button type="submit">ذخیره</button>
      <div class="msg"></div>
    </form>

    <form class="profile-form" data-field="address">
      <label>آدرس</label>
      <input type="text" name="value" value="<%= user.address || '' %>">
      <button type="submit">ذخیره</button>
      <div class="msg"></div>
    </form>

    <form class="profile-form" data-field="password">
      <label>رمز عبور جدید</label>
      <input type="password" name="value" placeholder="********">
      <button type="submit">ذخیره</button>
      <div class="msg"></div>
    </form>
  </div>
</div>
